{
  "name": "multi-llm-talk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "ux:unify": "node ux-synthesizer/unify-ux.mjs",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "login": "tsx src/cli-login.ts",
    "postinstall": "node -e \"if (process.env.VERCEL) process.exit(0); require('child_process').execSync('npx playwright install firefox', { stdio: 'inherit' })\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "playwright": "^1.49.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
