# Copy to .env.local for local dev (never commit .env.local).

# ── Clerk (auth) ─────────────────────────────────────────────────────────
# https://dashboard.clerk.com/ — create app → API Keys
# Keyless dev: omit keys and use the dashboard prompt in the browser.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Showcase / Vercel UI-only deploy ─────────────────────────────────────
SHOWCASE_MODE=1

# Durable production database. Set this in Vercel for hosted deployments.
# DATABASE_URL=postgres://...

# Optional: server-side model keys (local dev / self-host only).
# Local dev can use per-provider keys or OpenRouter via the Settings toggle.
BYOK_ONLY=1
# Optional: extra allowed Origins (comma-separated). The URL users open (Host /
# X-Forwarded-Host) is always allowed so custom domains match the browser Origin.
# Add entries here only for additional origins (e.g. second domain or local dev).
# ALLOWED_ORIGINS=https://your-second-domain.com,http://localhost:3010
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_FALLBACK=1
# Optional OpenRouter attribution (defaults: VERCEL_URL → HTTP-Referer, title "Neuralmob")
# OPENROUTER_HTTP_REFERER=https://your-app.vercel.app
# OPENROUTER_APP_TITLE=Neuralmob

# Login is email-only (cookie); no AUTH_SECRET required for that flow.
# Local dev: ENFORCE_BILLING=1 mirrors hosted credit rules for testing.
# Future SSO: add Clerk — NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY, CLERK_SECRET_KEY (replace cookie session).
# ENFORCE_BILLING=1

# ── Vercel / production (real LLM + billing) ────────────────────────────────
# Add real values only in Vercel → Settings → Environment Variables (never in git).
# SHOWCASE_MODE=0
# DATABASE_URL=postgres://...
# OPENROUTER_API_KEY=   (paste in Vercel dashboard only)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# ALLOWED_ORIGINS=https://your-app.vercel.app
# FREE_STARTER_CREDIT_CENTS=50
# MODEL_MAX_OUTPUT_TOKENS=2048
# RUN_COST_SAFETY_MULTIPLIER=1.35
# Optional: comma-separated emails that skip all billing gates and are never charged.
# Must match the normalized login email (same as cookie). When you use Clerk later,
# use the primary email you sync into the session.
# OWNER_UNLIMITED_EMAILS=you@example.com
# OWNER_EMAIL=you@example.com
