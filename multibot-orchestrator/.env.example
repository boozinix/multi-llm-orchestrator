# Copy to .env.local for local dev (never commit .env.local).

# ── Showcase / Vercel UI-only deploy ─────────────────────────────────────
SHOWCASE_MODE=1

# Optional: server-side model keys (local dev / self-host only).
# On Vercel you can leave these empty — users paste keys in the app Settings UI.
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# XAI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# OPENROUTER_FALLBACK=1

# Login is email-only (cookie); no AUTH_SECRET required for that flow.
