<!DOCTYPE html>

<html class="dark" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                    "inverse-surface": "#dae2fd",
                    "on-secondary-fixed-variant": "#005236",
                    "surface-tint": "#d0bcff",
                    "on-surface": "#dae2fd",
                    "surface-container-high": "#222a3d",
                    "surface-container-highest": "#2d3449",
                    "on-secondary-container": "#00311f",
                    "primary": "#d0bcff",
                    "inverse-on-surface": "#283044",
                    "tertiary": "#c6c5cf",
                    "on-tertiary-fixed-variant": "#46464e",
                    "on-tertiary-container": "#282931",
                    "surface-bright": "#31394d",
                    "secondary": "#4edea3",
                    "surface-variant": "#2d3449",
                    "error": "#ffb4ab",
                    "tertiary-container": "#909099",
                    "surface-container-lowest": "#060e20",
                    "background": "#0b1326",
                    "on-secondary-fixed": "#002113",
                    "on-error": "#690005",
                    "on-secondary": "#003824",
                    "error-container": "#93000a",
                    "outline-variant": "#494454",
                    "surface-dim": "#0b1326",
                    "primary-fixed-dim": "#d0bcff",
                    "primary-fixed": "#e9ddff",
                    "on-primary-fixed-variant": "#5516be",
                    "secondary-fixed-dim": "#4edea3",
                    "primary-container": "#a078ff",
                    "on-tertiary-fixed": "#1a1b22",
                    "on-background": "#dae2fd",
                    "surface": "#0b1326",
                    "on-tertiary": "#2f3038",
                    "surface-container": "#171f33",
                    "on-primary": "#3c0091",
                    "outline": "#958ea0",
                    "tertiary-fixed": "#e3e1ec",
                    "secondary-fixed": "#6ffbbe",
                    "tertiary-fixed-dim": "#c6c5cf",
                    "inverse-primary": "#6d3bd7",
                    "on-primary-container": "#340080",
                    "secondary-container": "#00a572",
                    "on-primary-fixed": "#23005c",
                    "surface-container-low": "#131b2e",
                    "on-surface-variant": "#cbc3d7",
                    "on-error-container": "#ffdad6"
            },
            "borderRadius": {
                    "DEFAULT": "0.25rem",
                    "lg": "0.5rem",
                    "xl": "0.75rem",
                    "full": "9999px"
            },
            "fontFamily": {
                    "headline": ["Inter"],
                    "body": ["Inter"],
                    "label": ["Inter"],
                    "mono": ["JetBrains Mono"]
            }
          },
        }
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-panel {
            background: rgba(45, 52, 73, 0.4);
            backdrop-filter: blur(12px);
        }
        .network-bg {
            background-image: radial-gradient(circle at 2px 2px, rgba(208, 188, 255, 0.05) 1px, transparent 0);
            background-size: 40px 40px;
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body antialiased min-h-screen flex items-center justify-center overflow-hidden">
<!-- Abstract Network Background -->
<div class="fixed inset-0 z-0 network-bg opacity-40"></div>
<div class="fixed inset-0 z-0 overflow-hidden">
<div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/10 rounded-full blur-[120px]"></div>
<div class="absolute bottom-[-5%] right-[-5%] w-[30%] h-[30%] bg-secondary/5 rounded-full blur-[100px]"></div>
</div>
<!-- Main Content Container -->
<main class="relative z-10 w-full max-w-md px-6">
<!-- Brand Header Section -->
<header class="text-center mb-10">
<div class="inline-flex items-center justify-center p-3 rounded-xl bg-surface-container-low mb-6">
<span class="material-symbols-outlined text-primary text-3xl" data-icon="hub">hub</span>
</div>
<h1 class="font-headline text-3xl font-extrabold tracking-tighter text-on-surface mb-3">
                MultiBot Orchestrator Pro
            </h1>
<p class="font-body text-on-surface-variant text-base leading-relaxed max-w-[280px] mx-auto">
                Orchestrate GPT-4, Claude 3.5, and Gemini 1.5 in a single workspace.
            </p>
</header>
<!-- Access Gate Card -->
<section class="glass-panel p-8 rounded-2xl shadow-2xl shadow-surface-container-lowest/50 border border-outline-variant/15">
<div class="space-y-6">
<!-- Input Field -->
<div class="space-y-2">
<label class="font-mono text-[10px] uppercase tracking-widest text-on-surface-variant/70 block px-1" for="email">
                        Authorization Endpoint
                    </label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-outline text-lg" data-icon="alternate_email">alternate_email</span>
<input class="w-full bg-surface-container-lowest text-on-surface border-none rounded-xl py-4 pl-12 pr-4 focus:ring-1 focus:ring-primary/40 placeholder:text-outline/50 transition-all duration-300" id="email" placeholder="name@company.ai" type="email"/>
</div>
</div>
<!-- Primary CTA -->
<button class="group w-full relative overflow-hidden bg-gradient-to-br from-primary to-primary-container text-on-primary-container font-headline font-bold py-4 rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/30 transition-all duration-300 active:scale-[0.98]">
<span class="relative z-10 flex items-center justify-center gap-2">
                        Continue with Email
                        <span class="material-symbols-outlined text-xl transition-transform group-hover:translate-x-1" data-icon="arrow_forward">arrow_forward</span>
</span>
</button>
<!-- Divider with Mono Metadata -->
<div class="flex items-center gap-4 py-2">
<div class="h-[1px] flex-1 bg-outline-variant/30"></div>
<span class="font-mono text-[10px] text-outline/50 uppercase tracking-widest">Protocol: Secure</span>
<div class="h-[1px] flex-1 bg-outline-variant/30"></div>
</div>
<!-- Secondary Actions -->
<div class="grid grid-cols-2 gap-3">
<button class="flex items-center justify-center gap-2 py-3 rounded-xl bg-surface-container-high hover:bg-surface-bright text-on-surface text-sm font-medium transition-colors border border-outline-variant/10">
<span class="material-symbols-outlined text-lg" data-icon="key">key</span>
                        SSO
                    </button>
<button class="flex items-center justify-center gap-2 py-3 rounded-xl bg-surface-container-high hover:bg-surface-bright text-on-surface text-sm font-medium transition-colors border border-outline-variant/10">
<span class="material-symbols-outlined text-lg" data-icon="terminal">terminal</span>
                        API
                    </button>
</div>
</div>
</section>
<!-- Micro-copy & Metadata -->
<footer class="mt-8 text-center space-y-4">
<p class="font-body text-xs text-on-surface-variant/60 leading-relaxed px-4">
                By entering, you agree to our Pro Terms. <br/>
<span class="text-secondary font-medium">Only 10 runs per day for free users.</span>
</p>
<div class="flex items-center justify-center gap-6 opacity-40">
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-sm" data-icon="security">security</span>
<span class="font-mono text-[10px]">AES-256</span>
</div>
<div class="flex items-center gap-2">
<span class="material-symbols-outlined text-sm" data-icon="bolt">bolt</span>
<span class="font-mono text-[10px]">v1.5.2-stable</span>
</div>
</div>
</footer>
</main>
<!-- Visual Decor: Model Nodes (Asymmetric) -->
<div class="fixed top-20 right-[15%] w-32 h-32 opacity-20 pointer-events-none">
<div class="relative w-full h-full">
<div class="absolute top-0 right-0 p-2 rounded-lg bg-surface-container-highest border border-primary/20">
<span class="material-symbols-outlined text-primary" data-icon="neurology" data-weight="fill" style="font-variation-settings: 'FILL' 1;">neurology</span>
</div>
<div class="absolute bottom-4 left-0 p-2 rounded-lg bg-surface-container-highest border border-secondary/20 scale-75">
<span class="material-symbols-outlined text-secondary" data-icon="model_training">model_training</span>
</div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[1px] h-20 bg-gradient-to-b from-primary/0 via-primary/50 to-primary/0 rotate-45"></div>
</div>
</div>
<!-- Status Bar (Bento style bottom bit) -->
<div class="fixed bottom-6 left-1/2 -translate-x-1/2 flex gap-4 px-4 py-2 rounded-full glass-panel border border-outline-variant/10">
<div class="flex items-center gap-2">
<div class="w-1.5 h-1.5 rounded-full bg-secondary animate-pulse"></div>
<span class="font-mono text-[9px] uppercase tracking-tighter text-on-surface-variant">System Ready</span>
</div>
<div class="w-[1px] h-3 bg-outline-variant/30 my-auto"></div>
<div class="flex items-center gap-2">
<span class="font-mono text-[9px] uppercase tracking-tighter text-on-surface-variant">Nodes: 03 Active</span>
</div>
</div>
</body></html>