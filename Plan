4. Flow Orchestrator Logic (Backend Code Snippet)

typescript
// In /api/chat/route.ts
import { Litellm } from "@litellm/litellm";

async function runFlow(prompt: string, history: Message[], flow: string[]) {
  let outputs = {};
  for (const model of flow) {
    const response = await completion({
      model,
      messages: [...history, {role: "user", content: prompt}],
      apiKey: process.env[`${provider(model)}_API_KEY`],
    });
    outputs[model] = response.choices[0].message.content;
  }
  // Run merge prompt with outputs
  return mergePrompt(outputs, history, prompt);
}

